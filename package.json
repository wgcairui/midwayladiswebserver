{
  "name": "midwayladiswebserver",
  "version": "1.1.0",
  "description": "ladis网站后台服务",
  "private": true,
  "scripts": {
    "start": "NODE_ENV=production node ./bootstrap.js",
    "dev": "cross-env NODE_ENV=local midway-bin dev --ts  --entryFile=bootstrap.js",
    "test": "midway-bin test --ts",
    "cov": "midway-bin cov --ts",
    "lint": "mwts check",
    "lint:fix": "mwts fix",
    "ci": "npm run cov",
    "build": "midway-bin build -c",
    "check": "luckyeye",
    "build:docker": "docker compose build",
    "smoke": "./scripts/smoke.sh"
  },
  "dependencies": {
    "@cairui/wx-sdk": "^1.0.6",
    "@koa/cors": "^4.0.0",
    "@midwayjs/bootstrap": "^2.13.4",
    "@midwayjs/cache": "^2.13.4",
    "@midwayjs/core": "^2.13.4",
    "@midwayjs/decorator": "^2.13.2",
    "@midwayjs/koa": "^2.13.4",
    "@midwayjs/logger": "^2.19.3",
    "@midwayjs/typegoose": "^2.13.5",
    "@typegoose/typegoose": "^11.0.0",
    "axios": "^1.7.0",
    "cache-manager": "^3.4.3",
    "cheerio": "^1.0.0-rc.10",
    "class-validator": "^0.14.0",
    "crypto-js": "^4.0.0",
    "formidable": "^3.5.0",
    "jsonwebtoken": "^8.5.1",
    "koa-body": "^4.2.0",
    "mongoose": "^7.0.0",
    "node-fetch": "^2.6.1",
    "types-uart": "^1.1.7"
  },
  "devDependencies": {
    "@midwayjs/cli": "^1.3.11",
    "@midwayjs/luckyeye": "^1.0.0",
    "@midwayjs/mock": "^2.3.0",
    "@types/cache-manager": "^3.4.0",
    "@types/cheerio": "^0.22.35",
    "@types/crypto-js": "^4.2.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/koa": "^2.15.0",
    "@types/node": "^18.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mwts": "^1.0.5",
    "ts-jest": "^29.1.0",
    "types-uart": "^1.0.22",
    "typescript": "^4.9.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "patchedDependencies": {
    "@midwayjs/mock@2.3.0": "patches/@midwayjs__mock@2.3.0.patch"
  },
  "midway-bin-clean": [
    ".vscode/.tsbuildinfo",
    "dist"
  ],
  "midway-luckyeye": {
    "packages": [
      "midway_v2"
    ]
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "wgcairui@icloud.com",
  "license": "MIT"
}
